[
  { "keys": "alt+1", "command": { "action": "switchToTab", "index": 0 } },
  { "keys": "alt+2", "command": { "action": "switchToTab", "index": 1 } },
  { "keys": "alt+3", "command": { "action": "switchToTab", "index": 2 } },
  { "keys": "alt+4", "command": { "action": "switchToTab", "index": 3 } },
  { "keys": "alt+5", "command": { "action": "switchToTab", "index": 4 } },
  { "keys": "alt+6", "command": { "action": "switchToTab", "index": 5 } },
  { "keys": "alt+7", "command": { "action": "switchToTab", "index": 6 } },
  { "keys": "alt+8", "command": { "action": "switchToTab", "index": 7 } },
  { "keys": "alt+9", "command": { "action": "switchToTab", "index": 8 } },

  { "keys": "ctrl+alt+b", "command": { "action": "toggleBroadcastInput" } },

  { "keys": "ctrl+alt+up",   "command": { "action": "scrollToMark", "direction": "previous" } },
  { "keys": "ctrl+alt+down", "command": { "action": "scrollToMark", "direction": "next" } },
  { "keys": "ctrl+alt+m",    "command": { "action": "addMark" } },

  { "keys": "alt+left",  "command": { "action": "moveFocus", "direction": "left" } },
  { "keys": "alt+right", "command": { "action": "moveFocus", "direction": "right" } },
  { "keys": "alt+up",    "command": { "action": "moveFocus", "direction": "up" } },
  { "keys": "alt+down",  "command": { "action": "moveFocus", "direction": "down" } },

  { "keys": "alt+shift+left",  "command": { "action": "resizePane", "direction": "left" } },
  { "keys": "alt+shift+right", "command": { "action": "resizePane", "direction": "right" } },
  { "keys": "alt+shift+up",    "command": { "action": "resizePane", "direction": "up" } },
  { "keys": "alt+shift+down",  "command": { "action": "resizePane", "direction": "down" } },

  { "keys": "alt+shift+v", "command": { "action": "splitPane", "split": "vertical" } },
  { "keys": "alt+shift+s", "command": { "action": "splitPane", "split": "horizontal" } },
  { "keys": "alt+shift+u", "command": { "action": "duplicatePane" } },

  { "keys": "shift+f11", "command": "toggleFocusMode" },
  { "keys": "alt+k", "command": { "action": "sendInput", "input": "clear\r" } },
  { "keys": "win+`", "command": { "action": "globalSummon", "name": "_quake", "dropdownDuration": 200, "toggleVisibility": true, "monitor": "toMouse" } },
  { "keys": "ctrl+shift+f", "command": "find" }
]
